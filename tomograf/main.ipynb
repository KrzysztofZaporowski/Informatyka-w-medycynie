    "files = [f for f in os.listdir('./tomograf-obrazy/') if f.endswith('.jpg')]\n",
    "\n",
    "for f in files:\n",
    "    image = iio.imread(f'./tomograf-obrazy/{f}', mode='L')  \n",
    "    image = resize(image, (100, 100))\n",
    "    wymiar_y, wymiar_x = image.shape\n",
    "\n",
    "    liczba_detektorow = 180 \n",
    "    liczba_skanow = 180      \n",
    "    rozpietosc = 180         \n",
    "\n",
    "    sinogram_1 = utils.stworz_sinogram(wymiar_x, wymiar_y, liczba_detektorow, liczba_skanow, rozpietosc, image)\n",
    "    rekonstrukcja_1, historia_mse_11 = utils.rekonstrukcja_obrazu(wymiar_x, wymiar_y, liczba_detektorow, liczba_skanow, rozpietosc, sinogram_1, image)\n",
    "    rekonstrukcja_1_filtrowana, historia_mse_filtrowany_1 = utils.rekonstrukcja_obrazu(wymiar_x, wymiar_y, liczba_detektorow, liczba_skanow, rozpietosc, filter.filtruj_sinogram(sinogram_1), image)\n",
    "\n",
    "    utils.pokaz_historię_mse(historia_mse_11)\n",
    "    utils.pokaz_historię_mse(historia_mse_filtrowany_1)\n",
    "\n",
    "    fig, (ax1, ax2, ax3) = plt.subplots(1, 3, figsize=(18, 5))\n",
    "    ax1.imshow(image, cmap='gray')\n",
    "    ax1.set_title(\"Oryginalny obraz\")\n",
    "    ax2.imshow(rekonstrukcja_1, cmap='gray')\n",
    "    ax2.set_title(\"Rekonstruowany obraz\")\n",
    "    ax3.imshow(rekonstrukcja_1_filtrowana, cmap='gray')\n",
    "    ax3.set_title(\"Rekonstruowany obraz po filtracji\")\n",
    "    plt.show()"
   ]
  }
